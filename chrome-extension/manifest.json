{
  "manifest_version": 3,
  "name": "Airflow Task Log Viewer",
  "version": "1.0",
  "description": "Exibe logs de erro de tarefas do Airflow ao passar o mouse sobre elas.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "host do airflow"
  ],
  "content_scripts": [
    {
      "matches": [
        "host do airflow"
      ],
      "js": ["content.js"],
      "css": ["tooltip.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
